# Kompletní šablona proměnných je v souboru .env.example (vedle tohoto souboru).
#
# Lokální vývoj:
#   PowerShell:  Copy-Item .env.example .env.local
#   bash:        cp .env.example .env.local
# Potom vyplňte OPENAI_API_KEY, Supabase, DATABASE_URL atd. Soubor .env.local se necommituje.
#
# Vercel: Environment Variables — stejné názvy jako v apps/web/.env.example


# ── Claude Sidecar / Benchmark ────────────────────────────────────────────────
AI_REVIEW_PROVIDER=anthropic
AI_ASSISTANT_PROVIDER=openai
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-20250514
AI_REVIEW_PROVIDER_FALLBACK_TO_OPENAI=false
AI_REVIEW_PROVIDER_DEBUG=false
AI_REVIEW_ANTHROPIC_PDF_BLOCK=false
