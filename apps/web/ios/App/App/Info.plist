<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>CAPACITOR_DEBUG</key>
	<string>$(CAPACITOR_DEBUG)</string>
	<key>CFBundleDevelopmentRegion</key>
	<string>cs</string>
	<key>CFBundleLocalizations</key>
	<array>
		<string>cs</string>
		<string>en</string>
	</array>
	<key>CFBundleDisplayName</key>
        <string>Aidvisora</string>
	<key>CFBundleExecutable</key>
	<string>$(EXECUTABLE_NAME)</string>
	<key>CFBundleIdentifier</key>
	<string>$(PRODUCT_BUNDLE_IDENTIFIER)</string>
	<key>CFBundleInfoDictionaryVersion</key>
	<string>6.0</string>
	<key>CFBundleName</key>
	<string>$(PRODUCT_NAME)</string>
	<key>CFBundleURLTypes</key>
	<array>
		<dict>
			<key>CFBundleTypeRole</key>
			<string>Editor</string>
			<key>CFBundleURLName</key>
			<string>cz.aidvisora.app</string>
			<key>CFBundleURLSchemes</key>
			<array>
				<string>aidvisor</string>
				<string>aidvisora</string>
			</array>
		</dict>
	</array>
	<key>CFBundlePackageType</key>
	<string>APPL</string>
	<key>CFBundleShortVersionString</key>
	<string>$(MARKETING_VERSION)</string>
	<key>CFBundleVersion</key>
	<string>$(CURRENT_PROJECT_VERSION)</string>
	<key>LSRequiresIPhoneOS</key>
	<true/>
	<key>UILaunchStoryboardName</key>
	<string>LaunchScreen</string>
	<key>UIApplicationSceneManifest</key>
	<dict>
		<key>UIApplicationSupportsMultipleScenes</key>
		<false/>
		<key>UISceneConfigurations</key>
		<dict>
			<key>UIWindowSceneSessionRoleApplication</key>
			<array>
				<dict>
					<key>UISceneConfigurationName</key>
					<string>Default Configuration</string>
					<key>UISceneDelegateClassName</key>
					<string>$(PRODUCT_MODULE_NAME).SceneDelegate</string>
				</dict>
			</array>
		</dict>
	</dict>
	<key>UIRequiredDeviceCapabilities</key>
	<array>
		<string>arm64</string>
	</array>
	<key>ITSAppUsesNonExemptEncryption</key>
	<false/>
	<!--
	    Phone: portrait-only. The mobile shell's layout (MobileHeader, bottom
	    tab bar with safe-area, FullscreenSheet) isn't designed for landscape
	    rotation — allowing it led to clipped forms and drifted header back
	    buttons during the audit. iPad keeps full freedom because the portal
	    on tablet uses the desktop layout.
	-->
	<key>UISupportedInterfaceOrientations</key>
	<array>
		<string>UIInterfaceOrientationPortrait</string>
	</array>
	<key>UISupportedInterfaceOrientations~ipad</key>
	<array>
		<string>UIInterfaceOrientationPortrait</string>
		<string>UIInterfaceOrientationPortraitUpsideDown</string>
		<string>UIInterfaceOrientationLandscapeLeft</string>
		<string>UIInterfaceOrientationLandscapeRight</string>
	</array>
	<key>NSCameraUsageDescription</key>
	<string>Aidvisora potřebuje přístup ke kameře, abyste mohli vyfotit smlouvu nebo jiný dokument klienta přímo z aplikace a odeslat ho ke zpracování AI Review.</string>
	<key>NSPhotoLibraryUsageDescription</key>
	<string>Aidvisora potřebuje přístup k fotkám, abyste mohli vybrat existující sken nebo fotografii dokumentu a připojit ho ke klientovi.</string>
	<key>NSPhotoLibraryAddUsageDescription</key>
	<string>Aidvisora ukládá vygenerované PDF (např. výpověď smlouvy nebo export portfolia) do vaší knihovny fotek, pokud si vyberete sdílení obrázkem.</string>
	<key>NSFaceIDUsageDescription</key>
	<string>Aidvisora používá Face ID nebo Touch ID k rychlému odemknutí aplikace bez opakovaného zadávání hesla. Biometrická data neopouští vaše zařízení.</string>
	<key>UIBackgroundModes</key>
	<array>
		<string>remote-notification</string>
	</array>
	<key>UIViewControllerBasedStatusBarAppearance</key>
	<true/>
	<!--
	    UIStatusBarStyle: fallback style for contexts before the SPA's
	    StatusBar plugin call has run (cold launch + splash transition).
	    Use dark content on light surfaces to match web header. Per-VC
	    UIViewControllerBasedStatusBarAppearance takes precedence at runtime.
	-->
	<key>UIStatusBarStyle</key>
	<string>UIStatusBarStyleDarkContent</string>
	<!--
	    WKAppBoundDomains: paired with Capacitor's
	    `ios.limitsNavigationsToAppBoundDomains` (release only). Limits the
	    WKWebView to this allow-list of hosts — a mitigation against
	    third-party JS / iframe exfiltration attempts.
	-->
	<key>WKAppBoundDomains</key>
	<array>
		<string>aidvisora.cz</string>
		<string>www.aidvisora.cz</string>
	</array>
	<!--
	    Schemes we want to openURL from the WebView (tel:, mailto:, maps:,
	    itms-apps: for Store listing). iOS 9+ requires an explicit allowlist
	    before canOpenURL returns true.
	-->
	<key>LSApplicationQueriesSchemes</key>
	<array>
		<string>tel</string>
		<string>mailto</string>
		<string>sms</string>
		<string>maps</string>
		<string>comgooglemaps</string>
		<string>itms-apps</string>
	</array>
</dict>
</plist>
