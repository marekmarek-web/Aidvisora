{
  "installCommand": "cd ../.. && pnpm install",
  "buildCommand": "pnpm build",
  "regions": ["fra1"],
  "crons": [
    {
      "path": "/api/cron/fa-followup",
      "schedule": "0 6 * * *"
    },
    {
      "path": "/api/cron/service-reminders",
      "schedule": "0 7 * * *"
    },
    {
      "path": "/api/cron/reminder-check",
      "schedule": "0 8 * * *"
    },
    {
      "path": "/api/cron/escalation-check",
      "schedule": "0 9 * * *"
    },
    {
      "path": "/api/cron/analytics-snapshot",
      "schedule": "0 5 * * *"
    },
    {
      "path": "/api/cron/event-reminders",
      "schedule": "0 10 * * *"
    },
    {
      "path": "/api/cron/image-intake-cleanup",
      "schedule": "0 3 * * *"
    },
    {
      "path": "/api/cron/image-intake-cache-cleanup",
      "schedule": "0 4 * * *"
    },
    {
      "path": "/api/cron/grace-period-check",
      "schedule": "30 9 * * *"
    },
    {
      "path": "/api/cron/trash-purge-contacts",
      "schedule": "15 3 * * *"
    },
    {
      "path": "/api/cron/email-queue-worker",
      "schedule": "*/2 * * * *"
    },
    {
      "path": "/api/cron/email-automations",
      "schedule": "0 8 * * *"
    },
    {
      "path": "/api/cron/stuck-contract-reviews",
      "schedule": "*/15 * * * *"
    }
  ]
}
